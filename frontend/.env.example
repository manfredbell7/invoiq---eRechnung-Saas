# invoiq Frontend — Umgebungsvariablen (Vite)
# Kopie als .env.local anlegen; in Vercel unter Project → Settings → Environment Variables setzen.

# ── FEATURE-FLAGS ────────────────────────────────────────────
# ERP-Module (MM/PP/CO/HCM/CRM/PM/QM/DMS) + Vertriebs-Belegfluss
# (Belege & Aufträge, Artikel & Leistungen, Kunden) ein-/ausblenden.
# Der Code bleibt vollständig erhalten — "false" blendet nur die
# Navigation, Dashboard-Kacheln und Belegfluss-Karte aus.
# Zum Reaktivieren: auf "true" setzen und neu deployen.
# Entwickler-Override ohne Rebuild: localStorage.setItem("invoiq_feature_erp","1")
VITE_ERP_ENABLED=false

# ── API ──────────────────────────────────────────────────────
# Basis-URL des Backends inkl. /v1-Prefix (Railway).
# Ohne Angabe nutzt die App https://api.invoiq.io/v1.
# VITE_API_URL=https://api.invoiq.io/v1
