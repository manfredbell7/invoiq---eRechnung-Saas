# ─── SERVER ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# ─── DATABASE (Supabase / PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/invoiq
SUPABASE_URL=https://your-project.supabase.co
# WICHTIG: Der Code liest SUPABASE_SERVICE_ROLE_KEY
# (SUPABASE_SERVICE_KEY wird als Fallback-Alias akzeptiert).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AWS S3 (Frankfurt - GoBD Archiv) ─────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=invoiq-archive-prod

# ─── STRIPE ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Preis-IDs je Plan (monatlich + jährlich) — Namen müssen exakt so heißen,
# der Checkout liest STRIPE_PRICE_<PLAN> bzw. STRIPE_PRICE_<PLAN>_YEARLY.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# ─── EMAIL (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=rechnungen@invoiq.io
EMAIL_FROM_NAME=invoiq

# ─── PEPPOL (Storecove) ───────────────────────────────────────
STORECOVE_API_KEY=your-storecove-key
STORECOVE_SENDER_ID=your-sender-id

# ─── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
# Redis-backed Rate Limiting (PFLICHT in production — ohne REDIS_URL startet
# der Prozess in production NICHT; in dev/test fällt er mit Warnung auf
# In-Memory zurück).
REDIS_URL=redis://localhost:6379

# ─── FRONTEND ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── E-MAIL EINGANG (Mailgun Inbound) ─────────────────────────────
# Mailgun Account: mailgun.com → Sending → Domains → Add Domain → invoiq.io
# Dann: Receiving → Create Route → Catch-all → Forward to webhook
MAILGUN_API_KEY=key-...
MAILGUN_DOMAIN=invoiq.io
# HTTP Webhook Signing Key (Mailgun → Settings → API Security).
# PFLICHT in production: ohne diesen Key lehnt invoiq Inbound-Webhooks ab,
# da sonst jeder Rechnungen in fremde Konten einschleusen könnte.
MAILGUN_SIGNING_KEY=signing-key-...
# Webhook URL für Mailgun: https://api.invoiq.io/v1/inbound/email
#
# TODO (Inbound-Adresse pro Organisation — [slug]@rechnungen.invoiq.io):
# Der Code (DB → API → Frontend) ist bereits fertig verdrahtet
# (organizations.inbound_email_slug, GET /v1/auth/me & /v1/auth/settings,
# Anzeige in Dashboard/Einstellungen/Eingang). Damit eingehende Mails an
# [slug]@rechnungen.invoiq.io tatsächlich ankommen, fehlt noch:
#   1. Subdomain "rechnungen.invoiq.io" in Mailgun unter Sending → Domains
#      anlegen (oder bestehende invoiq.io-Domain per Receiving-Route nutzen).
#   2. MX/TXT/CNAME-Records für rechnungen.invoiq.io beim DNS-Provider setzen
#      (siehe Mailgun-Anleitung nach Domain-Anlage).
#   3. Mailgun Receiving-Route: match_recipient(".*@rechnungen.invoiq.io")
#      → forward("https://api.invoiq.io/v1/inbound/email")
# Bis dahin funktioniert die Adress-Anzeige im Frontend bereits korrekt,
# aber tatsächlich verschickte Test-Mails an diese Adresse werden nicht
# zugestellt/verarbeitet.

# ── PEPPOL (PeppolSoft — $0.10/Dokument, kein Abo) ──────────────
# Account: peppolsoft.com → Sign Up → API Keys
PEPPOLSOFT_API_KEY=psoft_...

# ── PDF RENDERER (optional) ──────────────────────────────────────
# npm install pdfkit  (im backend/)
# Ohne pdfkit: Fallback auf einfaches Text-PDF
