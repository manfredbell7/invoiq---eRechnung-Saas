# ─── SERVER ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# ─── DATABASE (Supabase / PostgreSQL) ─────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/invoiq
SUPABASE_URL=https://your-project.supabase.co
# WICHTIG: Der Code liest SUPABASE_SERVICE_ROLE_KEY
# (SUPABASE_SERVICE_KEY wird als Fallback-Alias akzeptiert).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AWS S3 (Frankfurt - GoBD Archiv) ─────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=invoiq-archive-prod

# ─── STRIPE ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Preis-IDs je Plan (monatlich + jährlich) — Namen müssen exakt so heißen,
# der Checkout liest STRIPE_PRICE_<PLAN> bzw. STRIPE_PRICE_<PLAN>_YEARLY.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...

# ─── EMAIL (Resend) ───────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=rechnungen@invoiq.io
EMAIL_FROM_NAME=invoiq

# ─── PEPPOL (Storecove) ───────────────────────────────────────
STORECOVE_API_KEY=your-storecove-key
STORECOVE_SENDER_ID=your-sender-id

# ─── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
# Redis-backed Rate Limiting (PFLICHT in production — ohne REDIS_URL startet
# der Prozess in production NICHT; in dev/test fällt er mit Warnung auf
# In-Memory zurück).
REDIS_URL=redis://localhost:6379

# ─── FRONTEND ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── E-MAIL EINGANG — Resend Inbound ───────────────────────────────
# Jeder Mandant hat eine persönliche Adresse [slug]@rechnungen.invoiq.io.
# Setup (siehe README → DNS-Setup):
#  1. Domain rechnungen.invoiq.io bei Resend anlegen + MX-Eintrag setzen
#  2. Resend → Webhooks → Endpoint https://api.invoiq.io/v1/webhooks/email-inbound
#     für das Event "email.received" anlegen
#  3. Das dort angezeigte Signing Secret (whsec_…) hier eintragen.
# Ohne Secret lehnt der Webhook alle Zustellungen ab (Schutz vor
# eingeschleusten Rechnungen); der Rest der App ist davon unabhängig.
RESEND_WEBHOOK_SECRET=whsec_...
# Abweichende Eingangs-Domain (Default: rechnungen.invoiq.io)
# INBOUND_EMAIL_DOMAIN=rechnungen.invoiq.io

# Alt-Pfad Mailgun (POST /v1/inbound/email) — nur falls noch genutzt:
INBOUND_SIGNING_KEY=

# ── PEPPOL (PeppolSoft — $0.10/Dokument, kein Abo) ──────────────
# Account: peppolsoft.com → Sign Up → API Keys
PEPPOLSOFT_API_KEY=psoft_...

# ── PDF RENDERER (optional) ──────────────────────────────────────
# npm install pdfkit  (im backend/)
# Ohne pdfkit: Fallback auf einfaches Text-PDF
